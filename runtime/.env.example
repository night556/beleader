# ── Runtime ────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values.
# Environment variables override .env, flags override environment.

# Listen port (default: 8081)
PORT=8083

# Gateway URL for auto-registration — omit to skip registration
GATEWAY_URL=http://127.0.0.1:8082

# Registration token, must match Gateway's GATEWAY_TOKEN
GATEWAY_TOKEN=rt_dev_xxx

# Public URL Gateway uses to reach this Runtime (default: http://127.0.0.1:{PORT})
RUNTIME_URL=http://127.0.0.1:8083

# Display name for this Runtime instance (default: hostname)
RUNTIME_NAME=my-machine

# Restrict file operations to workspace directory (default: false)
RESTRICT_WORKSPACE=false

# Data directory — persisted registration state (default: ~/.beleader/runtime)
# Thread data paths are passed per-request by Gateway; this dir is only for local state.
DATA_DIR=./data/runtime
