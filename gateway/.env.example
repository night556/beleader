# ── Gateway ─────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values.

# Listen port
PORT=8082

# SQLite database path (default: ~/.beleader/beleader.db)
DB_PATH=./data/gateway/gateway.db

# Thread data directory — Gateway computes thread_dir = {DATA_DIR}/threads/{id}
# and passes it to Runtime. Must be the same path mounted by all Runtimes.
DATA_DIR=./data/gateway

# Registration token — Runtime must provide the same token to register
GATEWAY_TOKEN=rt_dev_xxx

# Restrict file operations to workspace — applied to all threads
RESTRICT_WORKSPACE=false

# Log directory for rotating file logs (default: stdout)
LOG_DIR=
