# ── Network ──
# Port the tool-agent HTTP server listens on
PORT=8083

# Gateway URL for auto-registration
GATEWAY_URL=http://gateway:8082

# Registration token (must match GATEWAY_TOKEN on the gateway)
GATEWAY_TOKEN=rt_dev_xxx

# ── Pool ──
# Pool name to join (a pool is created if it doesn't exist)
POOL=workers

# ── Workspace ──
# Root directory for all thread workspaces
WORKSPACE_ROOT=/app/data

# If true, file operations are restricted to the workspace directory
RESTRICT_WORKSPACE=false

# ── Tools ──
# Comma-separated list of built-in tools to enable.
# If not set, ALL built-in tools are enabled.
# Available tools:
#   read_file, read_dir, write_file, edit_file, delete_file,
#   search_content, search_files,
#   run_command, task_output, task_stop,
#   web_search, web_fetch, run_http_request
#
# Example: TOOLS=read_file,read_dir,write_file,run_command,web_search
TOOLS=
