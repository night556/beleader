# ── Gateway ─────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values.

# Listen port
PORT=8082

# Database driver: sqlite, mysql, postgres (default: sqlite)
DB_DRIVER=sqlite

# SQLite path (when DB_DRIVER=sqlite)
DB_PATH=./data/gateway/gateway.db

# MySQL/PostgreSQL config (when DB_DRIVER=mysql or postgres)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=beleader
# DB_PASSWORD=
# DB_NAME=beleader

# Data directory
DATA_DIR=./data/gateway

# Registration token — Tool Agent must provide the same token to register
GATEWAY_TOKEN=rt_dev_xxx

# Log directory for rotating file logs (default: stdout)
LOG_DIR=
